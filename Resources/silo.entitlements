<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Intentionally NO com.apple.security.app-sandbox.
         Silo executes external wine binaries outside its bundle and reads/writes
         ~/Library/Application Support and the Steam bottle, which the App Sandbox forbids. -->
</dict>
</plist>
