# Silo — SINGLE SOURCE OF TRUTH for every version number in the project.
#
# Edit a version here, then regenerate the committed Swift mirror:
#   Scripts/gen-versions.sh        # writes Sources/SiloKit/Versions.swift
# (Scripts/build-app.sh runs it for you.) Nothing else in the repo should hard-code a version.
#
# Shell-sourceable (KEY=VALUE, no spaces) so every script AND the Swift codegen read the exact same values.

# --- Silo app ---
SILO_VERSION=0.3.5
# GitHub repo (owner/name). Hosts BOTH the app releases the updater checks AND the wine-cx-* runtime
# builds the Wine tab installs.
SILO_GITHUB_REPO=mikaelhug/Silo

# --- Wine runtime (built from CrossOver's FOSS source in CI) ---
# The CrossOver source version that Scripts/build-wine.sh / .github/workflows/build-wine.yml compile from
# (crossover-sources-<ver>.tar.gz at media.codeweavers.com/pub/crossover/source/). The app downloads the
# LATEST published wine-cx-* release at runtime, so this pins the BUILD input, not what the app loads.
# (CI's wine-autoupdate.yml may bump past this automatically when CrossOver ships a newer source.)
CROSSOVER_VERSION=26.2.0

# --- DXMT runtime (the optional older-games D3D10/11 backend) ---
# 3Shain's DXMT is the Metal translation layer Silo overlays as the GPTK fallback. Scripts/build-dxmt.sh
# / .github/workflows/build-dxmt.yml build it from this upstream tag against the CrossOver Wine above.
# Pinned to the EXACT version CrossOver 26 bundles, so DXMT ↔ Wine is the pairing CrossOver itself ships
# (CrossOver vendors DXMT from this same upstream — building it here keeps the canonical, reproducible
# build incl. its git submodules). DXMT is NOT Wine, so constraint #8 (Wine = CrossOver-FOSS only) is
# unaffected. LLVM_MINGW_VERSION is the cross-toolchain (mstorsjo/llvm-mingw) DXMT's cross-file pins.
DXMT_REPO=3Shain/dxmt
DXMT_VERSION=v0.72
LLVM_MINGW_VERSION=20231017
